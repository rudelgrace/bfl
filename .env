# ============================================================
# THE BATTLE 3x3 — Environment Config
# ============================================================
# BEFORE you go to your site, fill in the 5 values below.
# Everything else can stay as-is for most shared hosting setups.
# ============================================================

APP_NAME="BFL Management"
APP_VERSION="2.0.0"
APP_ENV=development

# Your site URL — no trailing slash
# Example: https://mydomain.com/battle3x3
BASE_URL=http://localhost/

# Database — get these from cPanel > MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bflthebattle_3x3
DB_USER=root
DB_PASS=""
DB_CHARSET=utf8mb4

MAX_FILE_SIZE_MB=2
